# Supabase Configuration
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Configuration
# Optional: If not set, the app will use relative URLs (/api) which work on any domain
# Set this for custom backend URLs or when backend is on a different domain
# Examples:
# VITE_API_BASE_URL=http://localhost:5000/api        # Local development
# VITE_API_BASE_URL=https://api.yourdomain.com/api   # Production on custom domain
# VITE_API_BASE_URL=/api                             # Relative path (same domain)
# VITE_API_BASE_URL=https://meetingmind-backend-faua.onrender.com/api  # Render backend
VITE_API_BASE_URL=
